# Copy this to .env and adjust as needed
# These values are the defaults — only override what you need to change

SAMPLING_FREQ=256
WINDOW_SIZE=256
WINDOW_STRIDE=128
N_CHANNELS=23

TEST_SPLIT=0.2
RANDOM_SEED=42
BATCH_SIZE=64
MAX_EPOCHS=30
LEARNING_RATE=0.001

SEIZURE_THRESHOLD=0.5
MODEL_NAME=cnn_seizure_detector
MODEL_VERSION=v1

API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

LOG_LEVEL=INFO
